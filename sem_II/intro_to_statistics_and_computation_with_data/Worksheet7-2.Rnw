plot(T1, col = 2, pch = 20, cex = 0.1, main = "T1", asp = 1)
plot(T2, col = 3, pch = 20, cex = 0.1, main = "T2", asp = 1)
plot(T3, col = 4, pch = 20, cex = 0.1, main = "T3", asp = 1)
plot(T4, col = 5, pch = 20, cex = 0.1, main = "T4", asp = 1)
plot(T5, col = 6, pch = 20, cex = 0.1, main = "T5", asp = 1)
			@
		\item
			<<>>=
filling_T <- function(a, b, c)
{
  points <- NULL
  lam1 <- seq(0, 1, length = 25)
  lam2 <- seq(0, 1, length = 25)
  for(l1 in lam1)
  {
    for(l2 in lam2)
    {
      if(l1 + l2 < 1) points <- rbind(points, l1*a + l2*b + (1 - l1 - l2)*c)
    }
  }
  points
}

points_T <- filling_T(corners_T[1,], corners_T[2, ], corners_T[3, ])

T0 <- points_T
T1 <- iterative_func(T0)
T2 <- iterative_func(T1)
T3 <- iterative_func(T2)
T4 <- iterative_func(T3)
T5 <- iterative_func(T4)

par(mfrow = c(2,3))
plot(T0, pch = 20, cex = 0.01, main = "T0 (Filled (not really, many points actually)", asp = 1)
plot(T1, col = 2, pch = 20, cex = 0.01, main = "T1", asp = 1)
plot(T2, col = 3, pch = 20, cex = 0.01, main = "T2", asp = 1)
plot(T3, col = 4, pch = 20, cex = 0.01, main = "T3", asp = 1)
plot(T4, col = 5, pch = 20, cex = 0.01, main = "T4", asp = 1)
plot(T5, col = 6, pch = 20, cex = 0.01, main = "T5", asp = 1)
			@
			I can not spot any difference but there is a difference between these theoretically, the removed triangles are way too small to be seen in the window I have the pdf reader open in, its half my screen for reference.
