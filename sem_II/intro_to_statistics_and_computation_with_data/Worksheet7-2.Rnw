	\item\begin{enumerate}[label=(\alph*)]
			\item 
			<<>>=
			affine_map = function(x, h, centroid, theta)
{
  c_old = matrix(c(0.5, 1/(2*sqrt(3))), ncol = 1)
  Rot_mat = matrix(c(cos(theta), sin(theta), -sin(theta), cos(theta)), nrow = 2, ncol = 2)
  x_vec = matrix(x, ncol = 1)
  c_new = matrix(centroid, ncol = 1)
  u = c_new - h * (Rot_mat %*% c_old)
  as.vector(h * (Rot_mat %*% x_vec) + u)
}
			@
		\item
			<<>>=
			par(mfrow = c(1,2))
T5_a <- t(apply(T5, 1, function(p) affine_map(p, 1, c(0,0), 0)))
plot(T5_a, col = 2, pch = 20, cex = 0.01, asp = 1)

T5_b <- t(apply(T5, 1, function(p) affine_map(p, 0.5, c(5,3), pi/6)))
plot(T5_b, col = 2, pch = 20, cex = 0.01, asp = 1)
@
	\end{enumerate}
\end{enumerate}
