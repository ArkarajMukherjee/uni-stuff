x = c(1,2,3,4,5,6)
#this creates a vector with the entries above to serve as the possible samples
probx = c(1/6,1/6,1/6,1/6,1/6,1/6)
#this creates another vector but this serves as the probability of getting some sample
Rolls = sample(x, size = 1500, replace = T, prob = probx)
#this samples from the distribution described by x and probx 1500 times with replacement and stores these in Rolls
Rollm = matrix(Rolls, nrow = 5)
#This creates a matrix out of Rolls by wrapping the vector such that the matrix has 5 rows, it will have 1500/5=300 columns
Rollsums = apply(Rollm, 2, sum)
#This sums the entries in each column and puts them in Rollsums, if we had 1 instead of 2 there then it'd have summed the rows
library(ggplot2)
